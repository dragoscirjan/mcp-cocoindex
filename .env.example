# Example environment variables for mcp-cocoindex
# Copy to .env and adjust as needed

# PostgreSQL settings
COCOINDEX_DB_HOST=localhost
COCOINDEX_DB_PORT=5432
COCOINDEX_DB_NAME=cocoindex
COCOINDEX_DB_USER=cocoindex
COCOINDEX_DB_PASSWORD=cocoindex

# Data directory for temporary files
COCOINDEX_DATA_DIR=/tmp/cocoindex

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# LLM settings for symbol extraction fallback (optional)
# Used when tree-sitter doesn't support a language and use_llm=true
#
# Supported api_type values:
# - openrouter - OpenRouter API (requires LLM_API_KEY)
# - openai     - OpenAI API (requires LLM_API_KEY)
# - anthropic  - Anthropic API (requires LLM_API_KEY)
# - ollama     - Local Ollama (no API key needed)
# - gemini     - Google Gemini (requires LLM_API_KEY)
# - vllm       - vLLM server (uses LLM_ADDRESS)
#
LLM_API_TYPE=ollama
LLM_MODEL=llama3.2
# LLM_API_KEY=your-api-key-here
# LLM_ADDRESS=http://localhost:11434

# Logging
LOG_LEVEL=INFO
